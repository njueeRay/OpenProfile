{
  // MCP 服务器运行时配置（VS Code 自动识别入口）
  // 参考：https://code.visualstudio.com/docs/copilot/agents/mcp-servers
  // 说明：为跨项目复用，模板文件位于 .github/mcp.json
  // 若修改本文件，请同步更新 .github/mcp.json

  "servers": {
    // GitHub MCP：用于查询仓库信息、README 结构、工作流状态等
    "github": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/",
      "gallery": true
    },

    // Fetch MCP：用于抓取参考主页、组件文档等外部资源
    "fetch": {
      "type": "stdio",
      "command": "uvx",
      "args": ["mcp-server-fetch"],
      "env": {}
    },

    // Memory MCP：跨会话知识图谱存储
    // 存储位置：.github/agents/knowledge/memory.jsonl（随仓库 git 管理）
    // 用途：用户偏好持久化、Agent 跨会话学习、重要决策记录
    // 安装：npx -y @modelcontextprotocol/server-memory 会自动下载
    "memory": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-memory"],
      "env": {
        "MEMORY_FILE_PATH": "${workspaceFolder}/.github/agents/knowledge/memory.jsonl"
      }
    },

    // Agent Skill Loader MCP：动态技能发现与加载
    // 用途：Agent 可以通过 list_skills/read_skill/install_skill 动态发现和加载技能
    // Skills 目录：.github/skills/（项目级，统一由 .github/ 管理）+ ~/.claude/skills/（全局）
    // 安装：npm install -g agent-skill-loader
    // 文档：https://github.com/back1ply/agent-skill-loader
    "agent-skill-loader": {
      "type": "stdio",
      "command": "agent-skill-loader"
    }
  }
}
